{
  "cSpell.enabled": false,
  "cSpell.ignorePaths": [
    "**/Cucumber Tests/**",
    "**/Playwright Tests/**",
    "**/node_modules/**",
    "**/.git/**"
  ],
  "[gherkin]": {
    "editor.formatOnSave": false
  },
  "gherkin.glueStepPaths": [
    "Cucumber Tests/step-definitions/**/*.js"
  ],
  "files.exclude": {
    "**/.DS_Store": true
  }
}
